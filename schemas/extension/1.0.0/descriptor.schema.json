{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://Copper.dev/schemas/extension/1.0.0/descriptor.schema.json",
  "title": "Copper Extension Descriptor",
  "type": "object",
  "required": ["id", "name", "version", "trigger", "actions"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "trigger": { "type": "string", "minLength": 1 },
    "permissions": {
      "type": "array",
      "items": { "enum": ["fs", "shell", "network", "store", "ui"] },
      "uniqueItems": true
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "label"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "type": {
            "enum": [
              "text",
              "number",
              "boolean",
              "folder-picker",
              "file-picker",
              "select",
              "multi-select"
            ]
          },
          "label": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "default": {},
          "options": {
            "type": "array",
            "items": { "type": "string" }
          },
          "optionsSource": { "type": "string", "minLength": 1 }
        }
      }
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "label", "script"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "script": { "type": "string", "minLength": 1 }
        }
      }
    },
    "ui": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": { "enum": ["list", "form", "detail", "toast"] },
        "source": { "type": "string" },
        "onSelect": { "type": "string" }
      }
    },
    "tray": {
      "type": "object",
      "required": ["provider", "title"],
      "additionalProperties": false,
      "properties": {
        "provider": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "tooltip": { "type": "string", "minLength": 1 }
      }
    },
    "settings": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "applyActions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "sections": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "title", "inputs"],
            "additionalProperties": false,
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "title": { "type": "string", "minLength": 1 },
              "description": { "type": "string", "minLength": 1 },
              "inputs": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 },
                "uniqueItems": true
              }
            }
          }
        },
        "status": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "title": { "type": "string", "minLength": 1 },
            "description": { "type": "string", "minLength": 1 },
            "fields": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["key", "label"],
                "additionalProperties": false,
                "properties": {
                  "key": { "type": "string", "minLength": 1 },
                  "label": { "type": "string", "minLength": 1 },
                  "format": {
                    "enum": ["text", "boolean", "number", "path", "date-time"]
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
