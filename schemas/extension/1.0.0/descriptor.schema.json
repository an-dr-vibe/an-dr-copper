{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://Copper.dev/schemas/extension/1.0.0/descriptor.schema.json",
  "title": "Copper Extension Descriptor",
  "type": "object",
  "required": ["id", "name", "version", "trigger", "actions"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "trigger": { "type": "string", "minLength": 1 },
    "permissions": {
      "type": "array",
      "items": { "enum": ["fs", "shell", "network", "store", "ui"] },
      "uniqueItems": true
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "label"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "type": {
            "enum": [
              "text",
              "number",
              "boolean",
              "folder-picker",
              "file-picker",
              "select"
            ]
          },
          "label": { "type": "string", "minLength": 1 },
          "default": {},
          "options": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "label", "script"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "script": { "type": "string", "minLength": 1 }
        }
      }
    },
    "ui": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": { "enum": ["list", "form", "detail", "toast"] },
        "source": { "type": "string" },
        "onSelect": { "type": "string" }
      }
    }
  }
}
